---
const repo = import.meta.env.PUBLIC_GISCUS_REPO ?? 'Campbell0/BLOG';
const repoId = import.meta.env.PUBLIC_GISCUS_REPO_ID ?? 'R_kgDOS7-jlA';
const category = import.meta.env.PUBLIC_GISCUS_CATEGORY ?? 'Announcements';
const categoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID ?? 'DIC_kwDOS7-jlM4C_Qnu';
const ready = repo && repoId && category && categoryId;
---

{ready && (
  <section class="comments">
    <div class="section-heading">
      <p class="eyebrow">comments</p>
      <h2>留下几句</h2>
      <p>评论区使用 GitHub Discussions 和 Giscus。</p>
    </div>

    <script is:inline src="https://giscus.app/client.js"
      data-repo={repo}
      data-repo-id={repoId}
      data-category={category}
      data-category-id={categoryId}
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="preferred_color_scheme"
      data-lang="zh-CN"
      crossorigin="anonymous"
      async>
    </script>
  </section>
)}
