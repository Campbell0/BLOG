---
import '@/styles/global.css';
import SearchPanel from '@/components/SearchPanel.astro';
import { site } from '@/site.config';

const {
  title = site.title,
  description = site.description,
  type = 'website',
  image = '/og-default.png',
} = Astro.props;

const siteUrl = Astro.site ?? site.url;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#faf9f7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111111" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={`${site.title} RSS`} href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:secure_url" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} share image`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <script is:inline>
      const storedTheme = localStorage.getItem('theme');
      const preferredTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = storedTheme || preferredTheme;
    </script>

    <title>{title}</title>
  </head>
  <body>
    <div class="progress-bar" data-progress-bar></div>
    <div class="sparkle-container" data-sparkles></div>

    <div class="page-shell">
      <header class="site-header">
        <div class="header-left">
          <button class="wave-button" type="button" aria-label="Wave">👋</button>
          <a class="brand" href="/" aria-label="返回首页">
            <span class="brand-mark">Campbell</span>
          </a>
        </div>

        <div class="header-right">
          <nav class="nav">
            <a href="/">Writing</a>
            <button type="button" data-search-open>Search</button>
            <a href="/rss.xml">RSS</a>
          </nav>
          <button class="theme-toggle" type="button" aria-label="切换主题" data-theme-toggle>
            <span class="theme-toggle__icon theme-toggle__sun" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <circle cx="12" cy="12" r="4"></circle>
                <path d="M12 2v2"></path>
                <path d="M12 20v2"></path>
                <path d="m4.93 4.93 1.41 1.41"></path>
                <path d="m17.66 17.66 1.41 1.41"></path>
                <path d="M2 12h2"></path>
                <path d="M20 12h2"></path>
                <path d="m6.34 17.66-1.41 1.41"></path>
                <path d="m19.07 4.93-1.41 1.41"></path>
              </svg>
            </span>
            <span class="theme-toggle__icon theme-toggle__moon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M20.99 12.42A8.5 8.5 0 1 1 11.58 3a6.5 6.5 0 0 0 9.41 9.42Z"></path>
              </svg>
            </span>
          </button>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <nav class="footer-links" aria-label="站点链接">
          <a href="https://github.com/Campbell0">GitHub</a>
        </nav>
      </footer>
    </div>

    <SearchPanel />

    <script is:inline>
      const root = document.documentElement;
      const progressBar = document.querySelector('[data-progress-bar]');
      const toggle = document.querySelector('[data-theme-toggle]');
      const sparkles = document.querySelector('[data-sparkles]');
      const wave = document.querySelector('.wave-button');

      const syncThemeIcon = () => {
        toggle?.setAttribute('aria-label', root.dataset.theme === 'dark' ? '切换到亮色模式' : '切换到暗色模式');
      };

      syncThemeIcon();

      const setTheme = (next) => {
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
        syncThemeIcon();
      };

      toggle?.addEventListener('click', () => {
        const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        toggle.classList.remove('is-switching-to-dark', 'is-switching-to-light');
        void toggle.offsetWidth;
        toggle.classList.add(`is-switching-to-${next}`);
        window.setTimeout(() => {
          toggle.classList.remove('is-switching-to-dark', 'is-switching-to-light');
        }, 620);

        if (!document.startViewTransition || reduceMotion) {
          setTheme(next);
          return;
        }

        root.classList.add('is-changing-theme');

        const transition = document.startViewTransition(() => setTheme(next));
        transition.finished.finally(() => {
          root.classList.remove('is-changing-theme');
        });
      });

      window.addEventListener('scroll', () => {
        const scrollTop = document.documentElement.scrollTop;
        const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
        if (progressBar) progressBar.style.width = `${progress}%`;
      }, { passive: true });

      document.querySelectorAll('[data-sparkle-link]').forEach((link) => {
        link.addEventListener('click', (event) => {
          if (!sparkles) return;
          for (let i = 0; i < 8; i += 1) {
            const dot = document.createElement('span');
            dot.className = 'sparkle';
            const angle = (Math.PI * 2 * i) / 8;
            const distance = 18 + Math.random() * 18;
            dot.style.left = `${event.clientX + Math.cos(angle) * distance}px`;
            dot.style.top = `${event.clientY + Math.sin(angle) * distance}px`;
            const size = 3 + Math.random() * 5;
            dot.style.width = `${size}px`;
            dot.style.height = `${size}px`;
            sparkles.appendChild(dot);
            window.setTimeout(() => dot.remove(), 650);
          }
        });
      });

      wave?.addEventListener('click', () => {
        wave.classList.remove('is-waving');
        void wave.offsetWidth;
        wave.classList.add('is-waving');
      });
    </script>
    <script is:inline src="/search.js" defer></script>
    <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token":"c60d81af2c7849c189560f78774c69cd"}'></script>
  </body>
</html>
