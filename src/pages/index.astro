---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';
import { site } from '@/site.config';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title={`${site.title} | ${site.author}`} description={site.description}>
  <section class="intro">
    <h1 class="intro-title">
      Java 后端开发。<br />
      写技术笔记，也写<span class="highlight">项目复盘</span>。
    </h1>
    <p class="intro-bio">
      这里是我的长期写作空间。不追求一次性写得多好，但尽量把问题、过程和判断记清楚。
      写给自己，也写给可能路过的人。
    </p>
  </section>

  <section class="posts-list">
    <div class="posts-label">Posts</div>
    <div class="timeline-list">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
