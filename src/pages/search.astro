---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPostSlug, getPostUrl, makeExcerpt, getPosts } from '@/lib/blog';
import { site } from '@/site.config';

type SearchItem = {
  id: string;
  title: string;
  description: string;
  tags: string[];
  date: string;
  href: string;
  excerpt: string;
};

const posts = await getPosts();
const searchIndex: SearchItem[] = posts.map((post) => ({
  id: getPostSlug(post),
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
  date: post.data.pubDate.toISOString(),
  href: getPostUrl(post),
  excerpt: makeExcerpt(post.body ?? '', 220),
}));
---

<BaseLayout title={`搜索 | ${site.title}`} description="在博客里查找文章、标签和内容。">
  <section class="search-command" data-search-root>
    <div class="search-command__top">
      <p class="posts-label">Search</p>
      <h1>找一篇文章</h1>
      <p>输入关键词后，会同时匹配标题、摘要、标签和正文片段。</p>
    </div>

    <label class="search-box" aria-label="站内搜索">
      <span class="search-box__icon">⌕</span>
      <input
        type="search"
        placeholder="搜索技术笔记、复盘、工程实践..."
        autocomplete="off"
        data-search-input
      />
      <kbd>/</kbd>
    </label>

    <div class="search-command__meta">
      <span data-search-count>{searchIndex.length} 篇文章</span>
      <span>Enter 打开第一条结果</span>
    </div>

    <div class="search-results" data-search-results></div>

    <script is:inline type="application/json" data-search-index set:html={JSON.stringify(searchIndex)}></script>
  </section>
</BaseLayout>
