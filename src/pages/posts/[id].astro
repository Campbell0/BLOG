---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { render } from 'astro:content';
import { formatDate, readingTime } from '@/lib/post';
import Comments from '@/components/Comments.astro';
import { getPosts, slugifyTag } from '@/lib/blog';
import { site } from '@/site.config';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      previousPost: posts[index - 1] ?? null,
      nextPost: posts[index + 1] ?? null,
    },
  }));
}

const { post, previousPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | ${site.title}`}
  description={post.data.description}
  type="article"
  image={post.data.ogImage ?? '/og-default.png'}
>
  <article class="article content-shell">
    <p class="eyebrow">article</p>
    <h1>{post.data.title}</h1>
    <div class="meta-line">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
      <span>{readingTime(post.body)} min read</span>
      {post.data.updatedDate && <span>更新于 {formatDate(post.data.updatedDate)}</span>}
    </div>

    {post.data.hero && <p class="hero__copy">{post.data.hero}</p>}

    {post.data.tags.length > 0 && (
      <ul class="tag-list article-tags" aria-label="标签">
        {post.data.tags.map((tag: string) => (
          <li>
            <a href={`/tags/${slugifyTag(tag)}/`}>#{tag}</a>
          </li>
        ))}
      </ul>
    )}

    <Content />
  </article>

  {(previousPost || nextPost) && (
    <nav class="article-nav content-shell" aria-label="文章导航">
      {previousPost && (
        <a class="article-nav__link" href={`/posts/${previousPost.id}/`}>
          <span class="article-nav__label">上一篇</span>
          <strong>{previousPost.data.title}</strong>
        </a>
      )}

      {nextPost && (
        <a class="article-nav__link article-nav__link--next" href={`/posts/${nextPost.id}/`}>
          <span class="article-nav__label">下一篇</span>
          <strong>{nextPost.data.title}</strong>
        </a>
      )}
    </nav>
  )}

  <Comments />
</BaseLayout>
