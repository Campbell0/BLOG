---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/site.config';
---

<BaseLayout title={`关于 | ${site.title}`} description={site.description}>
  <section class="content-shell about-panel">
    <p class="eyebrow">about</p>
    <h1 class="hero__title" style="font-size: clamp(2.4rem, 5vw, 4rem); max-width: 12ch;">{site.about.title}</h1>
    {site.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
  </section>
</BaseLayout>
