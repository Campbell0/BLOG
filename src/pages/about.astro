---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/site.config';
---

<BaseLayout title={`关于 | ${site.title}`} description="了解 Campbell 的技术栈、写作主题和博客方向。">
  <section class="content-shell about-panel">
    <p class="eyebrow">about</p>
    <h1 class="about-title">{site.about.title}</h1>
    {site.about.intro.map((paragraph) => <p>{paragraph}</p>)}

    <div class="about-grid">
      <section>
        <h2>技术栈</h2>
        <ul>
          {site.about.stack.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section>
        <h2>写作主题</h2>
        <ul>
          {site.about.topics.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    </div>

    <div class="about-links">
      {site.about.links.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
  </section>
</BaseLayout>
